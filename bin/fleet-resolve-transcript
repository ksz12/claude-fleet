#!/usr/bin/env python3
"""fleet-resolve-transcript <session-name> [--usage]

Resolve a session NAME to its Claude transcript .jsonl, WITHOUT having had to
capture the conversation id at launch.

Resolution order:
  1. cached claude_conversation_id in the session/archive state file
     -> ~/.claude/projects/<slug>/<id>.jsonl
  2. derive <slug> from working_directory (cwd with non-alphanumerics -> '-')
     and pick the newest *.jsonl in that project dir.

With --usage, also parse the transcript and print token totals + turn count
(transcripts include message.usage per assistant message).
"""
import json, os, sys, glob, re, argparse

FLEET_DIR = os.environ.get("FLEET_DIR", os.path.expanduser("~/.claude/fleet"))
PROJECTS = os.path.expanduser("~/.claude/projects")


def load_state(name):
    for d in ("sessions", "archive"):
        p = os.path.join(FLEET_DIR, d, name + ".json")
        if os.path.exists(p):
            with open(p) as f:
                return json.load(f)
    return None


def slug_for(path):
    # observed Claude convention: cwd with every non-alphanumeric -> '-'
    return re.sub(r"[^A-Za-z0-9]", "-", path)


def resolve(name):
    st = load_state(name)
    if not st:
        return None
    cid = st.get("claude_conversation_id") or ""
    wd = st.get("working_directory") or ""
    if cid and wd:
        cand = os.path.join(PROJECTS, slug_for(wd), cid + ".jsonl")
        if os.path.exists(cand):
            return cand
    # fall back to newest transcript in the derived project dir
    if wd:
        proj = os.path.join(PROJECTS, slug_for(wd))
        files = glob.glob(os.path.join(proj, "*.jsonl"))
        if files:
            return max(files, key=os.path.getmtime)
    # last resort: if we have a cached id, scan all projects for it
    if cid:
        hits = glob.glob(os.path.join(PROJECTS, "*", cid + ".jsonl"))
        if hits:
            return hits[0]
    return None


def usage(path):
    tin = tout = cache_r = cache_w = turns = 0
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except ValueError:
                continue
            if obj.get("type") == "assistant":
                u = (obj.get("message") or {}).get("usage") or {}
                tin += u.get("input_tokens", 0)
                tout += u.get("output_tokens", 0)
                cache_r += u.get("cache_read_input_tokens", 0)
                cache_w += u.get("cache_creation_input_tokens", 0)
                turns += 1
    return {"input_tokens": tin, "output_tokens": tout,
            "cache_read_input_tokens": cache_r,
            "cache_creation_input_tokens": cache_w,
            "assistant_turns": turns}


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("name")
    ap.add_argument("--usage", action="store_true")
    a = ap.parse_args()
    path = resolve(a.name)
    if not path:
        print("could not resolve transcript for: %s" % a.name, file=sys.stderr)
        sys.exit(1)
    if a.usage:
        print(json.dumps({"transcript": path, "usage": usage(path)}, indent=2))
    else:
        print(path)


if __name__ == "__main__":
    main()
