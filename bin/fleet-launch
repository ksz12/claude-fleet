#!/usr/bin/env bash
# fleet-launch --name NAME --repo DIR --prompt-file FILE [--task t-001]
#
# Mechanical, reliable launch of one interactive Claude session in tmux.
# Called by the /background skill after it has done the intelligent parts
# (prompt expansion, naming, repo resolution, confirmation).
#
# Set FLEET_LAUNCH_DRYRUN=1 to print the plan without touching tmux (for tests).
# Set FLEET_LAUNCH_CMD to override the launched command (test with e.g. "cat").

set -u
DIR="$(cd "$(dirname "$0")" && pwd)"
. "$DIR/fleet-lib.sh"
fleet_ensure_dirs

NAME=""; REPO=""; PROMPT_FILE=""; TASK=""
while [ $# -gt 0 ]; do
  case "$1" in
    --name) NAME="$2"; shift 2 ;;
    --repo) REPO="$2"; shift 2 ;;
    --prompt-file) PROMPT_FILE="$2"; shift 2 ;;
    --task) TASK="$2"; shift 2 ;;
    *) echo "fleet-launch: unknown arg: $1" >&2; shift ;;
  esac
done

[ -z "$NAME" ] && { echo "fleet-launch: --name required" >&2; exit 1; }
[ -z "$REPO" ] && { echo "fleet-launch: --repo required" >&2; exit 1; }
[ -z "$PROMPT_FILE" ] && { echo "fleet-launch: --prompt-file required" >&2; exit 1; }
[ ! -f "$PROMPT_FILE" ] && { echo "fleet-launch: prompt file not found: $PROMPT_FILE" >&2; exit 1; }

mkdir -p "$REPO"
REPO="$(cd "$REPO" && pwd)"
REPO_ROOT="$(fleet_repo_root "$REPO")"
PROMPT="$(cat "$PROMPT_FILE")"
NOW="$(fleet_now)"
CLAUDE_BIN="${FLEET_LAUNCH_CMD:-$(command -v claude 2>/dev/null || echo claude)}"

# --- register session state (status starts as "starting") ---
f="$SESS_DIR/$NAME.json"
jq -n --arg name "$NAME" --arg prompt "$PROMPT" --arg sa "$NOW" \
      --arg wd "$REPO" --arg rr "$REPO_ROOT" --arg task "$TASK" \
  '{name:$name,prompt:$prompt,started_at:$sa,status:"starting",working_directory:$wd,repo_root:$rr,claude_conversation_id:"",transcript_path:"",current_task:$task,latest_activity:$sa,tmux_session:$name}' \
  > "$f.tmp.$$" && mv "$f.tmp.$$" "$f"

# --- index: cwd -> name (correlation fallback) ---
[ -f "$INDEX" ] || echo '{}' > "$INDEX"
jq --arg c "$REPO" --arg n "$NAME" '.[$c]=$n' "$INDEX" > "$INDEX.tmp.$$" && mv "$INDEX.tmp.$$" "$INDEX"

if [ "${FLEET_LAUNCH_DRYRUN:-0}" = "1" ]; then
  echo "[dry-run] would: tmux new-session -d -s $NAME -c $REPO"
  echo "[dry-run] would launch: FLEET_SESSION_NAME=$NAME $CLAUDE_BIN --dangerously-skip-permissions"
  echo "[dry-run] would paste prompt from: $PROMPT_FILE"
  echo "[dry-run] registered: $f"
  exit 0
fi

if tmux has-session -t "$NAME" 2>/dev/null; then
  echo "fleet-launch: tmux session '$NAME' already exists" >&2; exit 1
fi

tmux new-session -d -s "$NAME" -c "$REPO"
# ALWAYS cd to the repo, then launch claude interactively with name injection
tmux send-keys -t "$NAME" "cd $(printf '%q' "$REPO") && FLEET_SESSION_NAME=$(printf '%q' "$NAME") $CLAUDE_BIN --dangerously-skip-permissions" Enter

# --- wait for a TRULY-ready bypass prompt before pasting -----------------------
# Choke we're guarding against: on a brand-new repo dir the "trust this folder"
# dialog renders first. The old code treated "? for shortcuts" as ready and
# pasted DURING that transition — the paste got swallowed AND the session settled
# outside bypass mode. Fix: auto-accept the trust dialog, then require the actual
# "bypass permissions on" footer (we ALWAYS launch with the flag) before pasting.
# "? for shortcuts" alone is NOT sufficient — it shows pre-bypass and racing it
# is exactly what broke.
ready=0
i=0
trusted=0
while [ $i -lt 120 ]; do
  pane="$(tmux capture-pane -t "$NAME" -p 2>/dev/null)"
  case "$pane" in
    *"trust this folder"*|*"Yes, I trust"*)
      if [ "$trusted" -eq 0 ]; then
        tmux send-keys -t "$NAME" Enter   # selects default "1. Yes, I trust"
        trusted=1
      fi
      i=$((i+1)); sleep 1; continue ;;
  esac
  case "$pane" in
    *"bypass permissions on"*) ready=1; break ;;   # primary: real bypass footer
    *"Welcome back"*)          ready=1; break ;;   # resumed dir (still bypass)
  esac
  i=$((i+1)); sleep 1
done

# settle so the input box is fully interactive before we touch it
[ "$ready" -eq 1 ] && sleep 2

# --- paste the prompt, then VERIFY it landed before submitting ------------------
# load-buffer + paste-buffer (bracketed), NEVER send-keys for the multi-line body.
# Confirm a stable needle from the prompt actually appears in the pane and retry
# the paste up to 3x, so a swallowed paste no longer silently no-ops.
needle="$(grep -m1 -v '^[[:space:]]*$' "$PROMPT_FILE" | cut -c1-40)"
buf="fleet-$NAME"
pasted=0
attempt=0
while [ $attempt -lt 3 ]; do
  tmux send-keys -t "$NAME" C-u            # clear any stray chars on the line
  sleep 0.4
  tmux load-buffer -b "$buf" "$PROMPT_FILE"
  sleep 0.5
  tmux paste-buffer -p -b "$buf" -t "$NAME"
  sleep 1.5
  pane="$(tmux capture-pane -t "$NAME" -p 2>/dev/null)"
  if [ -n "$needle" ] && printf '%s' "$pane" | grep -qF -- "$needle"; then
    pasted=1; break
  fi
  attempt=$((attempt+1))
done
tmux delete-buffer -b "$buf" 2>/dev/null

# --- submit, then VERIFY acceptance (footer flips to "esc to interrupt") --------
submitted=0
if [ "$pasted" -eq 1 ]; then
  s=0
  while [ $s -lt 3 ]; do
    tmux send-keys -t "$NAME" Enter
    sleep 2
    pane="$(tmux capture-pane -t "$NAME" -p 2>/dev/null)"
    case "$pane" in *"esc to interrupt"*) submitted=1; break ;; esac
    s=$((s+1))
  done
fi

# --- pop the session into its own Terminal.app window (alt-tab target) ---
# Always-on for interactive launches. Disable with FLEET_NO_WINDOW=1 (set in
# headless/cron contexts). Best-effort: failure here never fails the launch.
if [ "${FLEET_NO_WINDOW:-0}" != "1" ] && [ "$(uname)" = "Darwin" ] && command -v osascript >/dev/null 2>&1; then
  osascript >/dev/null 2>&1 <<OSA &
tell application "Terminal"
  do script "tmux attach -t $NAME"
  activate
end tell
OSA
  echo "opened a new Terminal window attached to $NAME"
fi

if [ "$submitted" -eq 1 ]; then
  echo "launched: $NAME  ->  tmux attach -t $NAME   (prompt sent & confirmed processing)"
elif [ "$pasted" -eq 1 ]; then
  echo "launched: $NAME  ->  tmux attach -t $NAME   (WARNING: prompt pasted but submission unconfirmed — check the pane)"
else
  echo "launched: $NAME  ->  tmux attach -t $NAME   (WARNING: prompt did NOT land — check the pane and re-send)"
fi
